{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./bin/promptly-telemetry.mjs hook --tool codex",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./bin/promptly-telemetry.mjs hook --tool codex",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./bin/promptly-telemetry.mjs hook --tool codex",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./bin/promptly-telemetry.mjs hook --tool codex",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
