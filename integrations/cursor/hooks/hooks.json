{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node ./bin/promptly-telemetry.mjs hook --tool cursor"
      }
    ],
    "stop": [
      {
        "command": "node ./bin/promptly-telemetry.mjs hook --tool cursor"
      }
    ],
    "sessionStart": [
      {
        "command": "node ./bin/promptly-telemetry.mjs hook --tool cursor"
      }
    ],
    "sessionEnd": [
      {
        "command": "node ./bin/promptly-telemetry.mjs hook --tool cursor"
      }
    ]
  }
}
