{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/bin/promptly-telemetry.mjs\" hook --tool cursor"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/bin/promptly-telemetry.mjs\" hook --tool cursor"
      }
    ],
    "stop": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/bin/promptly-telemetry.mjs\" hook --tool cursor"
      }
    ],
    "sessionStart": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/bin/promptly-telemetry.mjs\" hook --tool cursor"
      }
    ],
    "sessionEnd": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/bin/promptly-telemetry.mjs\" hook --tool cursor"
      }
    ]
  }
}
