# =============================================================================
# Promptly — Vercel environment template (NO REAL SECRETS)
# =============================================================================
# 1) Copy this file:  cp .env.vercel.template .env.vercel.local
# 2) Replace every REPLACE_* and paste values from your local website/.env.local
# 3) Set URLs to your real Vercel deployment (HTTPS):
#    NEXT_PUBLIC_APP_URL=https://YOUR-PROJECT.vercel.app
#    APP_BASE_URL=https://YOUR-PROJECT.vercel.app
# 4) Add each KEY=VALUE in Vercel → Project → Settings → Environment Variables
#    (or use Vercel CLI: vercel env pull / push per their docs)
#
# Do NOT commit .env.vercel.local — it contains secrets.
# =============================================================================

# --- Required: public base URL (must be HTTPS in production) ---
NEXT_PUBLIC_APP_URL=REPLACE_WITH_https://YOUR_PROJECT.vercel.app
APP_BASE_URL=REPLACE_WITH_https://YOUR_PROJECT.vercel.app

# --- Required: Firebase client (same as Firebase Console → Web app) ---
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_ME.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_ME

# --- Optional Firebase client (include if you use them in Console) ---
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_ME.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=REPLACE_ME

# --- Required: Firebase Admin (choose ONE approach) ---
# Approach A — three variables (common on Vercel). Private key must keep \n escapes:
FIREBASE_ADMIN_PROJECT_ID=REPLACE_ME
FIREBASE_ADMIN_CLIENT_EMAIL=REPLACE_ME
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_LINE_BY_LINE\n-----END PRIVATE KEY-----\n"

# Approach B — single JSON line (comment out A if you use this):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...",...}

# --- Required: OpenAI ---
OPENAI_API_KEY=REPLACE_ME

# --- Optional: models (defaults exist in code if omitted) ---
OPENAI_MODEL=gpt-5-nano
OPENAI_MODEL_AUTO=gpt-5-nano
OPENAI_MODEL_MANUAL=gpt-5-mini
OPENAI_MODEL_CREATE=gpt-5-mini
# OPENAI_MODEL_REWRITE=
# OPENAI_MODEL_GENERATE=

# --- Optional: timeouts (ms) ---
OPENAI_REWRITE_TIMEOUT_MS=15000
OPENAI_CREATE_TIMEOUT_MS=30000

# --- Optional: Stripe billing ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_STUDENT=
# STRIPE_PRICE_ID_ENTERPRISE=
