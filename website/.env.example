# Admin password is currently hardcoded in lib/adminAuth.ts (oat123).
# When you move to env, add ADMIN_PASSWORD here and read it in adminAuth.

# Public app URL used by the extension/account links (use https://promptly-labs.com in production)
NEXT_PUBLIC_APP_URL=https://promptly-labs.com
APP_BASE_URL=https://promptly-labs.com

# Google Search Console site verification token (HTML tag method)
# GOOGLE_SITE_VERIFICATION=your-verification-token

# Optional: shown on /privacy as an additional contact (store support email is always referenced)
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@yourdomain.com

# Optional browser store metadata used by the website-to-extension bridge.
# Keep Chrome's production ID in code; set these after each store assigns a stable ID/listing URL.
# NEXT_PUBLIC_EDGE_EXTENSION_ID=
# NEXT_PUBLIC_EDGE_ADDONS_URL=
# NEXT_PUBLIC_FIREFOX_ADDONS_URL=
# NEXT_PUBLIC_SAFARI_EXTENSION_ID=
# NEXT_PUBLIC_SAFARI_EXTENSION_URL=

# Firebase web app config (required for /account and /auth/extension)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=auth.promptly-labs.com
# Use your-project-id.firebaseapp.com until custom auth domain (above) is live in Firebase Console.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin (required for /api/credits and /api/optimize)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Or provide the full service account JSON instead of the three vars above:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"..."}

# Optional: dedicated key for encrypting vendor OAuth tokens stored for live Refresh (defaults to Firebase admin key)
# VENDOR_USAGE_TOKEN_SECRET=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano
OPENAI_MODEL_AUTO=gpt-5-nano
OPENAI_MODEL_MANUAL=gpt-5-nano
OPENAI_MODEL_CREATE=gpt-5-nano
OPENAI_REWRITE_TIMEOUT_MS=20000
OPENAI_CREATE_TIMEOUT_MS=45000
OPENAI_MODEL_REWRITE_FALLBACK=gpt-4.1-mini
OPENAI_MODEL_CREATE_FALLBACK=gpt-4.1-mini

# Stripe (billing — optional until you go live)
# Dashboard → Developers → API keys: Secret key (server only). Webhook signing secret after creating an endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs are defined in lib/server/stripe.ts (Pro, Student, Enterprise).
# Optional legacy overrides — not used by checkout once stripe.ts constants are set.
# STRIPE_PRICE_ID_PRO=price_1TdR2QE1kSqm5DoEqQGEdSMh
# STRIPE_PRICE_ID_STUDENT=price_1TdQyCE1kSqm5DoEwAxzcAiY
# STRIPE_PRICE_ID_ENTERPRISE=price_1TbGQtE1kSqm5DoEzuLyhaz6
# Promo codes in Checkout (default true)
STRIPE_ALLOW_PROMO_CODES=true
# Optional subscription trials — off by default. Set STRIPE_TRIALS_ENABLED=true to turn on.
# STRIPE_TRIALS_ENABLED=false
# STRIPE_TRIAL_DAYS=7
# STRIPE_TRIAL_DAYS_PRO=7
# STRIPE_TRIAL_DAYS_STUDENT=14
# STRIPE_TRIAL_DAYS_ENTERPRISE=14
